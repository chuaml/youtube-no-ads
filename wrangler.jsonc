{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "youtube-no-ads",
  "pages_build_output_dir": "./dist",
  "assets": {
    "directory": "./dist"
  },
  "compatibility_date": "2026-03-01",
  "vars": {
    "NODE_VERSION": "24.11"
  },
  "observability": {
    "enabled": true
  },
}