// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
    "name": "dev-container",
    // "image": "mcr.microsoft.com/devcontainers/javascript-node:24",    // for using pre-built image only without additional config
    "workspaceFolder": "/app",    // must align with compose.dev.yml
    "service": "dev-container",
    "dockerComposeFile": [
        "../compose.dev.yml"    // recommend to keep compose.yml in project root dir, to avoid relative path issues
    ],
    "remoteUser": "root",
    "customizations": {
        "vscode": {
            "extensions": [    // ext to include in remote vscode
                "alefragnani.Bookmarks",
                "usernamehw.errorlens",
                "dbaeumer.vscode-eslint",
                "eamodio.gitlens",
                "google.gemini-cli-vscode-ide-companion"
            ]
        }
    },
    "postCreateCommand": "pwd && ls && npm -v && whoami",
    "postStartCommand": "pwd && whoami"
    //
    // "features": {
    // 	// // increase huge xxx MB for addon tools --that are not come with original image-- in dev container
    // 	// // https://github.com/devcontainers/features/tree/main/src/common-utils
    // 	// "ghcr.io/devcontainers/features/common-utils:2.5.6": {}, // required for other installing other features, e.g. git
    // 	// "ghcr.io/devcontainers/features/git:1.3.5": {}
    // },
    //
    // Use 'forwardPorts' to make a list of ports inside the container available locally.
    // "forwardPorts": [],
    // Uncomment the next line if you want start specific services in your Docker Compose config.
    // "runServices": [],
    // Uncomment the next line if you want to keep your containers running after VS Code shuts down.
    // "shutdownAction": "none",
    // Uncomment the next line to run commands after the container is created.
    // Uncomment to connect as an existing user other than the container default. More info: https://aka.ms/dev-containers-non-root.
}